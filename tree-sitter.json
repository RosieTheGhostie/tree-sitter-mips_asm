{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mips_asm",
      "camelcase": "MipsAsm",
      "title": "MIPS Assembly",
      "scope": "source.mips",
      "file-types": [
        "asm",
        "mips",
        "s"
      ],
      "injection-regex": "^mips_asm$",
      "class-name": "TreeSitterMipsAsm"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "LGPL-3.0+",
    "description": "MipsAsm grammar for tree-sitter",
    "authors": [
      {
        "name": "RosieTheGhostie",
        "email": "rosetheghost.dev@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/RosieTheGhostie/tree-sitter-mips_asm",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}