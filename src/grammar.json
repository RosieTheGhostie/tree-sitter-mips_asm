{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mips_asm",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_item"
        },
        {
          "type": "SYMBOL",
          "name": "label_definition"
        }
      ]
    },
    "_line_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "directive"
            },
            {
              "type": "SYMBOL",
              "name": "instruction"
            }
          ]
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "line_break"
          }
        }
      ]
    },
    "directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directive_token"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "value",
              "content": {
                "type": "SYMBOL",
                "name": "directive_value"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "instruction": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "operator",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "operand"
              },
              {
                "type": "STRING",
                "value": ","
              }
            ]
          }
        }
      ]
    },
    "label_definition": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          },
          "named": true,
          "value": "label"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": ":"
          }
        }
      ]
    },
    "directive_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": ","
          },
          {
            "type": "STRING",
            "value": "("
          },
          {
            "type": "STRING",
            "value": ")"
          },
          {
            "type": "SYMBOL",
            "name": "integer"
          },
          {
            "type": "SYMBOL",
            "name": "float"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "identifier"
          },
          {
            "type": "SYMBOL",
            "name": "register"
          }
        ]
      }
    },
    "operand": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          },
          "named": true,
          "value": "label"
        },
        {
          "type": "SYMBOL",
          "name": "register"
        }
      ]
    },
    "line_break": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "directive_token": {
      "type": "PATTERN",
      "value": "\\.[a-z]+"
    },
    "integer": {
      "type": "PATTERN",
      "value": "0(?:[Bb][01]+|[Oo][0-7]+|[Xx][\\dA-Fa-f]+)|(?:[+-]?\\d+)"
    },
    "float": {
      "type": "PATTERN",
      "value": "[+-]?(\\d+([.]\\d*)?([eE][+-]?\\d+)?|[.]\\d+([eE][+-]?\\d+)?)"
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "unescaped_characters"
              },
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "unescaped_characters": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\"\\\\\\n\\r]+"
      }
    },
    "escape_sequence": {
      "type": "PATTERN",
      "value": "\\\\(?:[^ux0-7]|[0-7]{1,3}|x[\\dA-Fa-f]{2}|u[\\dA-Fa-f]{4})"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[\\p{L}_](?:\\.?[\\p{N}\\p{L}_])*",
      "flags": "u"
    },
    "register": {
      "type": "PATTERN",
      "value": "\\$[\\dA-Za-z]+"
    },
    "comment": {
      "type": "PATTERN",
      "value": "#.*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}