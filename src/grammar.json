{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mips_asm",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_item"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "line_break"
            }
          }
        ]
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "directive"
        },
        {
          "type": "SYMBOL",
          "name": "instruction"
        },
        {
          "type": "SYMBOL",
          "name": "label_definition"
        }
      ]
    },
    "directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directive_token"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "value",
              "content": {
                "type": "SYMBOL",
                "name": "directive_value"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "instruction": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "operator",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "operand"
              },
              {
                "type": "SYMBOL",
                "name": "comma"
              }
            ]
          }
        }
      ]
    },
    "label_definition": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": ":"
          }
        }
      ]
    },
    "directive_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comma"
          },
          {
            "type": "SYMBOL",
            "name": "left_parenthesis"
          },
          {
            "type": "SYMBOL",
            "name": "right_parenthesis"
          },
          {
            "type": "SYMBOL",
            "name": "integer"
          },
          {
            "type": "SYMBOL",
            "name": "float"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "identifier"
          },
          {
            "type": "SYMBOL",
            "name": "register"
          }
        ]
      }
    },
    "operand": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          },
          "named": true,
          "value": "label"
        },
        {
          "type": "SYMBOL",
          "name": "register"
        }
      ]
    },
    "line_break": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "comma": {
      "type": "STRING",
      "value": ","
    },
    "left_parenthesis": {
      "type": "STRING",
      "value": "("
    },
    "right_parenthesis": {
      "type": "STRING",
      "value": ")"
    },
    "directive_token": {
      "type": "PATTERN",
      "value": "\\.[a-z]+"
    },
    "integer": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "0[Oo][0-7]+"
        },
        {
          "type": "PATTERN",
          "value": "[+-]?\\d+"
        },
        {
          "type": "PATTERN",
          "value": "0[Xx][\\dA-Fa-f]+"
        }
      ]
    },
    "float": {
      "type": "PATTERN",
      "value": "[+-]?(\\d+([.]\\d*)?([eE][+-]?\\d+)?|[.]\\d+([eE][+-]?\\d+)?)"
    },
    "string": {
      "type": "PATTERN",
      "value": "\"([^\"\\\\\\x00-\\x1f]|\\\\[^\\x00-\\x1f])*\""
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[\\p{L}_](?:\\.?[\\p{N}\\p{L}_])*",
      "flags": "u"
    },
    "register": {
      "type": "PATTERN",
      "value": "\\$[\\dA-Za-z]+"
    },
    "comment": {
      "type": "PATTERN",
      "value": "#.*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\f\\t\\v\\u0020\\u00a0\\u1680\\u2000-\\u200a\\u2028\\u2029\\u202f\\u205f\\u3000\\ufeff]+"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}